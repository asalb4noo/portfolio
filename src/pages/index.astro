    href: 'https://vimeo.com/user20849775',
    path: 'M23.9765 6.4168c-.105 2.338-1.739 5.5429-4.894 9.6088-3.2679 4.247-6.0258 6.3699-8.2898 6.3699-1.409 0-2.578-1.294-3.553-3.881l-1.9179-7.1138c-.719-2.584-1.488-3.878-2.312-3.878-.179 0-.806.378-1.8809 1.132l-1.129-1.457a315.06 315.06 0 003.501-3.1279c1.579-1.368 2.765-2.085 3.5539-2.159 1.867-.18 3.016 1.1 3.447 3.838.465 2.953.789 4.789.971 5.5069.5389 2.45 1.1309 3.674 1.7759 3.674.502 0 1.256-.796 2.265-2.385 1.004-1.589 1.54-2.797 1.612-3.628.144-1.371-.395-2.061-1.614-2.061-.574 0-1.167.121-1.777.391 1.186-3.8679 3.434-5.7568 6.7619-5.6368 2.4729.06 3.6279 1.664 3.4929 4.7969z',
  },
  {
    label: 'Instagram',
    href: 'https://www.instagram.com/asalb4noo',
    path: 'M7.0301.084c-1.2768.0602-2.1487.264-2.911.5634-.7888.3075-1.4575.72-2.1228 1.3877-.6652.6677-1.075 1.3368-1.3802 2.127-.2954.7638-.4956 1.6365-.552 2.914-.0564 1.2775-.0689 1.6882-.0626 4.947.0062 3.2586.0206 3.6671.0825 4.9473.061 1.2765.264 2.1482.5635 2.9107.308.7889.72 1.4573 1.388 2.1228.6679.6655 1.3365 1.0743 2.1285 1.38.7632.295 1.6361.4961 2.9134.552 1.2773.056 1.6884.069 4.9462.0627 3.2578-.0062 3.668-.0207 4.9478-.0814 1.28-.0607 2.147-.2652 2.9098-.5633.7889-.3086 1.4578-.72 2.1228-1.3881.665-.6682 1.0745-1.3378 1.3795-2.1284.2957-.7632.4966-1.636.552-2.9124.056-1.2809.0692-1.6898.063-4.948-.0063-3.2583-.021-3.6668-.0817-4.9465-.0607-1.2797-.264-2.1487-.5633-2.9117-.3084-.7889-.72-1.4568-1.3876-2.1228C21.2982 1.33 20.628.9208 19.8378.6165 19.074.321 18.2017.1197 16.9244.0645 15.6471.0093 15.236-.005 11.977.0014 8.718.0076 8.31.0215 7.0301.0839m.1402 21.6932c-1.17-.0509-1.8053-.2453-2.2287-.408-.5606-.216-.96-.4771-1.3819-.895-.422-.4178-.6811-.8186-.9-1.378-.1644-.4234-.3624-1.058-.4171-2.228-.0595-1.2645-.072-1.6442-.079-4.848-.007-3.2037.0053-3.583.0607-4.848.05-1.169.2456-1.805.408-2.2282.216-.5613.4762-.96.895-1.3816.4188-.4217.8184-.6814 1.3783-.9003.423-.1651 1.0575-.3614 2.227-.4171 1.2655-.06 1.6447-.072 4.848-.079 3.2033-.007 3.5835.005 4.8495.0608 1.169.0508 1.8053.2445 2.228.408.5608.216.96.4754 1.3816.895.4217.4194.6816.8176.9005 1.3787.1653.4217.3617 1.056.4169 2.2263.0602 1.2655.0739 1.645.0796 4.848.0058 3.203-.0055 3.5834-.061 4.848-.051 1.17-.245 1.8055-.408 2.2294-.216.5604-.4763.96-.8954 1.3814-.419.4215-.8181.6811-1.3783.9-.4224.1649-1.0577.3617-2.2262.4174-1.2656.0595-1.6448.072-4.8493.079-3.2045.007-3.5825-.006-4.848-.0608M16.953 5.5864A1.44 1.44 0 1 0 18.39 4.144a1.44 1.44 0 0 0-1.437 1.4424M5.8385 12.012c.0067 3.4032 2.7706 6.1557 6.173 6.1493 3.4026-.0065 6.157-2.7701 6.1506-6.1733-.0065-3.4032-2.771-6.1565-6.174-6.1498-3.403.0067-6.156 2.771-6.1496 6.1738M8 12.0077a4 4 0 1 1 4.008 3.9921A3.9996 3.9996 0 0 1 8 12.0077',
  },
  {
    label: 'Email',
    href: `mailto:${site.contactEmail}`,
    path: 'M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z',
  }
];

const artworks = (await getCollection('artworks')).sort(
  (a, b) => (a.data.order ?? 0) - (b.data.order ?? 0)
);
const categories = ['All', ...new Set(artworks.map((a) => a.data.category))];

const hues: Record<string, number> = {
  Character: 265,
  Environment: 155,
  Creature: 330,
  Vehicle: 32,
};

// Shape each mosaic cell from the cover's real orientation. A uniform grid can't
// fit every aspect perfectly, so we bucket the cover into wide / square /
// portrait / tall and hand back a column + row span; `grid-auto-flow: dense`
// then packs the varied tiles. Featured pieces get an oversized hero tile.
// The base row unit is ~half a column (see `.bento` CSS), so a 2-row tile reads
// as square, a 3-row tile as portrait, etc.
function tileSpan(w: number, h: number, featured: boolean) {
  const ar = w / h;
  let col: number, row: number;
  if (ar >= 1.45) { col = 2; row = 2; }       // landscape → wide
  else if (ar <= 0.62) { col = 1; row = 4; }  // tall portrait
  else if (ar <= 0.85) { col = 1; row = 3; }  // portrait
  else { col = 1; row = 2; }                  // square-ish
  if (featured) {                             // hero — bigger, taller if portrait
    col = 2;
    row = ar <= 0.85 ? 4 : 3;
  }
  return { col, row };
}

// Resolve each artwork's images. The mosaic card shows the cover (`image`);
// the lightbox browses the whole set — cover first, then any `gallery` images.
// For each slide we precompute a large variant (lightbox) and a small one
// (thumbnail strip). astro:assets generates responsive WebP at build.
const items = await Promise.all(
  artworks.map(async (a) => {
    const img = getArtworkImage(a.data.image);
    const names = [a.data.image, ...(a.data.gallery ?? [])];
    const slides = await Promise.all(
      names.map(async (name) => {
        const src = getArtworkImage(name);
        const full = await getImage({ src, width: 1600, format: 'webp', quality: 80 });
        const thumb = await getImage({ src, width: 200, format: 'webp', quality: 70 });
        return { full: full.src, thumb: thumb.src };
      })
    );
    return { data: a.data, img, slides };
  })
);

// Serializable payload for the client-side lightbox.
const lb = items.map((it) => ({
  slides: it.slides, // [{ full, thumb }, ...] — cover first
  title: it.data.title,
  category: it.data.category,
  project: it.data.project ?? '',
  description: it.data.description ?? '',
  video: it.data.video ?? '',
}));
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{site.siteTitle}</title>
    <meta name="description" content={site.metaDescription} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" sizes="16x16 32x32 48x48" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <style>
      :root { --bg: #08080c; --panel: #101019; --ink: #f0f0f5; --muted: #8b8b9a; --line: rgba(255,255,255,0.08); }
      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body { margin: 0; background: var(--bg); color: var(--ink); font-family: 'Inter', sans-serif; overflow-x: hidden; }

      /* Cursor spotlight */
      .spotlight { position: fixed; inset: 0; z-index: 1; pointer-events: none; transition: background 0.15s; background: radial-gradient(600px circle at 50% 0%, rgba(120,90,255,0.10), transparent 70%); }
      .shell { position: relative; z-index: 2; }

      nav {
        position: sticky; top: 0; z-index: 20; display: flex; align-items: center; justify-content: space-between;
        padding: 1.2rem 2.5rem; background: rgba(8,8,12,0.7); backdrop-filter: blur(14px); border-bottom: 1px solid var(--line);
      }
      .brand { font-family: 'Space Grotesk', sans-serif; font-weight: 700; font-size: 1.1rem; letter-spacing: 0.01em; }
      .brand .dot { color: #7c5cff; }
      nav .role { font-size: 0.75rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--muted); }

      /* Right side of the nav: role text + social links. A hairline separator
         divides the two. Icons sit muted and lift to the site's purple accent on
         hover — the same glow the filter chips use. */
      .nav-right { display: flex; align-items: center; gap: 1.1rem; }
      .socials { display: flex; align-items: center; gap: 0.3rem; padding-left: 1.1rem; border-left: 1px solid var(--line); }
      .social {
        display: grid; place-items: center; width: 34px; height: 34px; border-radius: 999px;
        color: var(--muted); border: 1px solid transparent;
        transition: color 0.25s, border-color 0.25s, box-shadow 0.25s, background 0.25s;
      }
      .social svg { width: 17px; height: 17px; fill: currentColor; display: block; }
      .social:hover {
        color: #fff; border-color: #7c5cff; background: rgba(124,92,255,0.10);
        box-shadow: 0 0 16px rgba(124,92,255,0.35);
      }
      .social:focus-visible { outline: none; color: #fff; border-color: #7c5cff; box-shadow: 0 0 16px rgba(124,92,255,0.35); }

      .hero { padding: 6rem 2.5rem 2.5rem; max-width: 1100px; }
      .hero .eyebrow {
        display: inline-block; font-size: 0.78rem; letter-spacing: 0.22em; text-transform: uppercase;
        color: #c9beff; padding: 0.4rem 0.9rem; border: 1px solid var(--line); border-radius: 999px; margin-bottom: 1.75rem;
      }
      .hero h1 {
        font-family: 'Space Grotesk', sans-serif; font-weight: 700; font-size: clamp(2.6rem, 8vw, 6rem);
        line-height: 1; margin: 0; letter-spacing: -0.03em;
        background: linear-gradient(120deg, #fff 20%, #b7a6ff 60%, #6ee7ff 100%);
        -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;
      }
      .hero p { margin-top: 1.5rem; max-width: 44ch; color: var(--muted); font-size: 1.1rem; line-height: 1.6; }

      .filters { display: flex; flex-wrap: wrap; gap: 0.6rem; padding: 1.5rem 2.5rem 0; }
      .filters button {
        font-family: 'Space Grotesk', sans-serif; font-size: 0.82rem; padding: 0.5rem 1.1rem; border-radius: 999px; cursor: pointer;
        background: var(--panel); border: 1px solid var(--line); color: var(--muted); transition: all 0.25s;
      }
      .filters button.active, .filters button:hover { color: #fff; border-color: #7c5cff; box-shadow: 0 0 18px rgba(124,92,255,0.4); }

      /* Aspect-aware bento. The row unit is ~half a column (12.5vw at 4 cols), so
         a 2-row tile ≈ square, 3-row ≈ portrait, 4-row ≈ tall — and those shapes
         stay stable as the viewport scales instead of drifting into letterboxes.
         Per-tile spans come from the cover's orientation (see `tileSpan`). */
      .bento { display: grid; grid-template-columns: repeat(4, 1fr); grid-auto-rows: 12.5vw; gap: 1rem; grid-auto-flow: dense; padding: 2rem 2.5rem 7rem; }
      .card {
        --hue: 265; --col: 1; --row: 2; position: relative; overflow: hidden; border-radius: 16px; cursor: pointer;
        grid-column: span var(--col); grid-row: span var(--row);
        border: 1px solid var(--line); background: var(--panel);
        opacity: 0; transform: translateY(26px) scale(0.98);
        transition: opacity 0.6s ease, transform 0.6s ease, border-color 0.35s, box-shadow 0.35s;
      }
      .card.in { opacity: 1; transform: none; }
      .card img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.7s cubic-bezier(.2,.8,.2,1); filter: saturate(1.05) brightness(0.92); }
      .card:hover { border-color: hsl(var(--hue) 90% 65%); box-shadow: 0 0 0 1px hsl(var(--hue) 90% 65% / 0.5), 0 18px 50px hsl(var(--hue) 90% 40% / 0.28); }
      .card:hover img { transform: scale(1.07); filter: saturate(1.15) brightness(1); }
      .card .cap { position: absolute; left: 0; right: 0; bottom: 0; padding: 1.4rem 1.2rem 1.1rem; background: linear-gradient(to top, rgba(5,5,10,0.9), transparent); }
      .card .tag {
        display: inline-block; font-family: 'Space Grotesk', sans-serif; font-size: 0.66rem; font-weight: 600;
        letter-spacing: 0.08em; text-transform: uppercase; padding: 0.2rem 0.55rem; border-radius: 999px; margin-bottom: 0.5rem;
        color: hsl(var(--hue) 90% 82%); background: hsl(var(--hue) 90% 60% / 0.18); border: 1px solid hsl(var(--hue) 90% 65% / 0.4);
      }
      .card .t { font-family: 'Space Grotesk', sans-serif; font-weight: 600; font-size: 1.05rem; }
      .card .m { color: var(--muted); font-size: 0.82rem; margin-top: 0.15rem; }
      /* Play badge for pieces that have a video */
      .card .playbadge {
        position: absolute; top: 0.9rem; right: 0.9rem; z-index: 3; width: 34px; height: 34px;
        display: grid; place-items: center; border-radius: 999px; color: #fff; font-size: 0.72rem;
        background: rgba(8,8,12,0.6); border: 1px solid hsl(var(--hue) 90% 65% / 0.55); backdrop-filter: blur(3px);
      }
      /* Count badge for pieces with a gallery (cover + extra images) */
      .card .countbadge {
        position: absolute; top: 0.9rem; left: 0.9rem; z-index: 3; height: 34px; padding: 0 0.65rem;
        display: inline-flex; align-items: center; gap: 0.3rem; border-radius: 999px; color: #fff;
        font-family: 'Space Grotesk', sans-serif; font-size: 0.74rem; font-weight: 600;
        background: rgba(8,8,12,0.6); border: 1px solid hsl(var(--hue) 90% 65% / 0.55); backdrop-filter: blur(3px);
      }

      footer { padding: 3rem 2.5rem 5rem; border-top: 1px solid var(--line); color: var(--muted); font-size: 0.9rem; display: flex; justify-content: space-between; flex-wrap: wrap; gap: 1rem; }
      footer a { color: #b7a6ff; text-decoration: none; }

      /* Keep tiles from ballooning on very wide screens: more columns, smaller
         row unit (each ~half of the now-narrower column). */
      @media (min-width: 1700px) {
        .bento { grid-template-columns: repeat(5, 1fr); grid-auto-rows: 9.6vw; }
      }
      @media (max-width: 1100px) {
        .bento { grid-template-columns: repeat(3, 1fr); grid-auto-rows: 16vw; }
      }
      @media (max-width: 760px) {
        .bento { grid-template-columns: repeat(2, 1fr); grid-auto-rows: 24vw; }
        nav, .hero, .filters, .bento { padding-left: 1.25rem; padding-right: 1.25rem; }
        /* Drop the role label and tighten the icon row so all six fit next to
           the brand on a phone. */
        .nav-right .role { display: none; }
        .socials { padding-left: 0; border-left: none; gap: 0.1rem; }
        .social { width: 30px; height: 30px; }
        .social svg { width: 16px; height: 16px; }
      }
      @media (max-width: 380px) {
        nav { padding-left: 0.9rem; padding-right: 0.9rem; }
        .brand { font-size: 1rem; }
        .social { width: 28px; height: 28px; }
      }

      dialog#lb { border: none; background: transparent; max-width: 100vw; width: 100%; height: 100%; max-height: 100vh; padding: 0; }
      dialog#lb::backdrop { background: rgba(5,5,10,0.95); backdrop-filter: blur(4px); }
      .lb-inner { display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100%; padding: 3rem 2rem; position: relative; }
      .lb-inner img, .lb-inner video { max-height: 66vh; max-width: 82vw; object-fit: contain; border-radius: 8px; }
      .lb-inner video { background: #000; }
      .lb-meta { margin-top: 1.4rem; text-align: center; max-width: 560px; }
      .lb-meta h2 { font-family: 'Space Grotesk', sans-serif; margin: 0 0 0.35rem; }
      .lb-meta .m { color: #b7a6ff; text-transform: uppercase; letter-spacing: 0.08em; font-size: 0.78rem; }
      .lb-meta p { color: #b9b5c8; margin-top: 0.7rem; line-height: 1.55; }
      .lb-close, .lb-prev, .lb-next { position: absolute; background: none; border: none; font-size: 1.6rem; cursor: pointer; color: #fff; opacity: 0.7; }
      .lb-close:hover, .lb-prev:hover, .lb-next:hover { opacity: 1; }
      .lb-close { top: 1.5rem; right: 2rem; }
      .lb-prev { left: 2rem; top: 50%; }
      .lb-next { right: 2rem; top: 50%; }
      /* Position counter ("2 / 5") for a multi-image set */
      .lb-count {
        position: absolute; top: 1.6rem; left: 50%; transform: translateX(-50%);
        font-family: 'Space Grotesk', sans-serif; font-size: 0.78rem; letter-spacing: 0.1em; color: #c9beff;
        background: rgba(8,8,12,0.6); border: 1px solid var(--line); padding: 0.28rem 0.75rem; border-radius: 999px;
      }
      /* Thumbnail strip for jumping around a set */
      .lb-strip { display: flex; gap: 0.5rem; margin-top: 1.2rem; flex-wrap: wrap; justify-content: center; max-width: 82vw; }
      .lb-thumb {
        position: relative; width: 60px; height: 60px; padding: 0; border-radius: 8px; overflow: hidden; cursor: pointer;
        background: none; border: 2px solid transparent; opacity: 0.5; transition: opacity 0.2s, border-color 0.2s;
      }
      .lb-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
      .lb-thumb.active, .lb-thumb:hover { opacity: 1; border-color: #7c5cff; }
      .lb-thumb .tv { position: absolute; inset: 0; display: grid; place-items: center; color: #fff; font-size: 0.85rem; background: rgba(5,5,10,0.4); }
    </style>
  </head>
  <body>
    <div class="spotlight" id="spot"></div>
    <div class="shell">
      <nav>
        <div class="brand">{site.brand}<span class="dot">.</span></div>
        <div class="nav-right">
          <span class="role">{site.role}</span>
          <div class="socials">
            {socials.map((s) => {
              const external = !s.href.startsWith('mailto:');
              return (
                <a
                  class="social"
                  href={s.href}
                  aria-label={s.label}
                  title={s.label}
                  target={external ? '_blank' : undefined}
                  rel={external ? 'noopener noreferrer' : undefined}
                >
                  <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d={s.path} /></svg>
                </a>
              );
            })}
          </div>
        </div>
      </nav>

      <header class="hero">
        <span class="eyebrow">{site.heroEyebrow}</span>
        <h1>{headingLines.map((line, i) => (<Fragment>{i > 0 && <br />}{line}</Fragment>))}</h1>
        <p>{site.heroText}</p>
      </header>

      <div class="filters">
        {categories.map((c, i) => (
          <button class={i === 0 ? 'active' : ''} data-cat={c}>{c}</button>
        ))}
      </div>

      <div class="bento" id="grid">
        {items.map((it, i) => {
          const { col, row } = tileSpan(it.img.width, it.img.height, !!it.data.featured);
          return (
            <article class="card" data-cat={it.data.category} data-index={i} style={`--hue:${hues[it.data.category] ?? 265}; --col:${col}; --row:${row}`}>
              <Image
                src={it.img}
                alt={it.data.title}
                widths={[260, 380, 520, 760, 1040, 1400]}
                sizes="(max-width: 760px) 50vw, 33vw"
                format="webp"
                quality={78}
                loading={i < 6 ? 'eager' : 'lazy'}
              />
              {it.data.video && <span class="playbadge">▶</span>}
              {it.data.gallery && it.data.gallery.length > 0 && (
                <span class="countbadge">⧉ {it.data.gallery.length + 1}</span>
              )}
              <div class="cap">
                <span class="tag">{it.data.category}</span>
                <div class="t">{it.data.title}</div>
                <div class="m">{it.data.project}</div>
              </div>
            </article>
          );
        })}
      </div>

      <footer>
        <span>{site.footerText}</span>
        <a href={`mailto:${site.contactEmail}`}>{site.contactEmail}</a>
      </footer>
    </div>

    <dialog id="lb">
      <div class="lb-inner">
        <button class="lb-close" id="lbClose">✕</button>
        <div class="lb-count" id="lbCount"></div>
        <button class="lb-prev" id="lbPrev">‹</button>
        <button class="lb-next" id="lbNext">›</button>
        <img id="lbImg" src="" alt="" />
        <video id="lbVid" controls playsinline loop style="display:none"></video>
        <div class="lb-meta">
          <div class="m" id="lbMeta"></div>
          <h2 id="lbTitle"></h2>
          <p id="lbDesc"></p>
        </div>
        <div class="lb-strip" id="lbStrip"></div>
      </div>
    </dialog>

    <script define:vars={{ items: lb }}>
      // Cursor spotlight
      const spot = document.getElementById('spot');
      window.addEventListener('pointermove', (e) => {
        spot.style.background = `radial-gradient(600px circle at ${e.clientX}px ${e.clientY}px, rgba(124,92,255,0.12), transparent 70%)`;
      });

      // Scroll reveal
      const io = new IntersectionObserver((entries) => {
        entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } });
      }, { threshold: 0.1 });
      document.querySelectorAll('.card').forEach((c, i) => { c.style.transitionDelay = `${(i % 4) * 55}ms`; io.observe(c); });

      // Filter
      const grid = document.getElementById('grid');
      const filters = document.querySelector('.filters');
      filters.addEventListener('click', (e) => {
        const btn = e.target.closest('button'); if (!btn) return;
        filters.querySelectorAll('button').forEach((b) => b.classList.remove('active'));
        btn.classList.add('active');
        const cat = btn.dataset.cat;
        grid.querySelectorAll('.card').forEach((f) => {
          f.style.display = cat === 'All' || f.dataset.cat === cat ? '' : 'none';
        });
      });

      // Lightbox — one open piece at a time; the arrows/thumbnails browse
      // WITHIN that piece's media set (cover, then gallery images, then video
      // if present). Closing returns to the grid. (Option A.)
      const lb = document.getElementById('lb');
      const lbImg = document.getElementById('lbImg');
      const lbVid = document.getElementById('lbVid');
      const lbTitle = document.getElementById('lbTitle');
      const lbMeta = document.getElementById('lbMeta');
      const lbDesc = document.getElementById('lbDesc');
      const lbCount = document.getElementById('lbCount');
      const lbStrip = document.getElementById('lbStrip');
      const lbPrev = document.getElementById('lbPrev');
      const lbNext = document.getElementById('lbNext');

      let current = 0; // index of the open artwork
      let slide = 0;   // index within its media set
      let media = [];  // [{ type:'image', full, thumb } | { type:'video', src, thumb }]

      function openAt(i) {
        current = i;
        const a = items[i];
        media = a.slides.map((s) => ({ type: 'image', full: s.full, thumb: s.thumb }));
        if (a.video) media.push({ type: 'video', src: a.video, thumb: a.slides[0].thumb });

        lbTitle.textContent = a.title;
        lbMeta.textContent = [a.category, a.project].filter(Boolean).join(' · ');
        lbDesc.textContent = a.description ?? '';

        // Rebuild the thumbnail strip for this piece.
        lbStrip.innerHTML = '';
        media.forEach((m, k) => {
          const b = document.createElement('button');
          b.className = 'lb-thumb';
          b.innerHTML = `<img src="${m.thumb}" alt="" />` + (m.type === 'video' ? '<span class="tv">▶</span>' : '');
          b.addEventListener('click', () => showSlide(k));
          lbStrip.appendChild(b);
        });

        showSlide(0);
        lb.showModal();
      }

      function showSlide(j) {
        slide = (j + media.length) % media.length;
        const m = media[slide];
        if (m.type === 'video') {
          lbVid.src = m.src;
          lbVid.poster = items[current].slides[0].full;
          lbVid.style.display = '';
          lbImg.style.display = 'none';
        } else {
          lbVid.pause();
          lbVid.removeAttribute('src');
          lbVid.load();
          lbVid.style.display = 'none';
          lbImg.src = m.full;
          lbImg.alt = items[current].title;
          lbImg.style.display = '';
        }
        // Set controls only make sense when there's more than one item.
        const multi = media.length > 1;
        lbPrev.style.display = lbNext.style.display = multi ? '' : 'none';
        lbCount.style.display = multi ? '' : 'none';
        lbStrip.style.display = multi ? '' : 'none';
        lbCount.textContent = `${slide + 1} / ${media.length}`;
        lbStrip.querySelectorAll('.lb-thumb').forEach((b, k) => b.classList.toggle('active', k === slide));
      }

      grid.querySelectorAll('.card').forEach((f) => f.addEventListener('click', () => openAt(Number(f.dataset.index))));
      document.getElementById('lbClose').addEventListener('click', () => lb.close());
      lbPrev.addEventListener('click', () => showSlide(slide - 1));
      lbNext.addEventListener('click', () => showSlide(slide + 1));
      lb.addEventListener('click', (e) => { if (e.target === lb) lb.close(); });
      lb.addEventListener('close', () => lbVid.pause());
      window.addEventListener('keydown', (e) => {
        if (!lb.open) return;
        if (e.key === 'ArrowLeft') showSlide(slide - 1);
        if (e.key === 'ArrowRight') showSlide(slide + 1);
      });
    </script>
  </body>
</html>

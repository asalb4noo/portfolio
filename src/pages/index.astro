---
import { getCollection } from 'astro:content';
import { Image, getImage } from 'astro:assets';
import { getArtworkImage } from '../lib/media';
// Site-wide copy (title, hero text, footer, …). Editable from the local admin
// app ("Site text"), which writes this file. Everything user-facing on the page
// reads from here rather than being hard-coded.
import site from '../data/site.json';

// The hero heading may contain line breaks (stored as "\n"); render each on its
// own line so the artist can control the wrap from the admin.
const headingLines = site.heroHeading.split('\n');

// Social links shown in the top nav next to the role. These are intentionally
// NOT admin-managed — they change rarely. Edit the `href`s below to point at
// Asal's real profiles (the placeholders are just examples). The email icon
// reuses `site.contactEmail` so it always matches the footer. Each `path` is a
// monochrome glyph on a 0 0 24 24 viewBox (brand marks from simpleicons.org;
// the envelope is a Material icon), filled with `currentColor` so it inherits
// the nav's hover colour.
const socials = [
  {
    label: 'LinkedIn',
    href: 'https://www.linkedin.com/in/asal-sadeghinia-8aa13155',
    path: 'M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z',
  },
